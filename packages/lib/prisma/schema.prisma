generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String                   @id @default(cuid())
  name          String                   @db.VarChar(80)
  email         String                   @unique
  joined_at     DateTime                 @default(now())
  avatar        String                   @default("https://cdn-icons-png.flaticon.com/512/3177/3177440.png")
  bio           String?                  @db.VarChar(160)
  is_verified   Boolean                  @default(false)
  location      String?                  @db.VarChar(100)
  google_id     String?
  password      String?
  search_vector Unsupported("tsvector")?
  collection    Collection[]
  followers     Follow[]                 @relation("UserFollowing")
  following     Follow[]                 @relation("UserFollowers")
  likes         Like[]
  links         Links[]
  metrics       Metrics?
  pictures      Picture[]

  @@index([search_vector], map: "user_search_idx", type: Gin)
  @@index([name(ops: raw("gin_trgm_ops"))], map: "user_trgm_idx", type: Gin)
}

model Links {
  id      Int    @id @default(autoincrement())
  user_id String
  name    String @db.VarChar(30)
  url     String @db.VarChar(150)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, name])
  @@index([user_id])
}

model Metrics {
  user_id         String @id
  follower        Int    @default(0)
  following       Int    @default(0)
  total_downloads Int    @default(0)
  total_likes     Int    @default(0)
  user            User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Follow {
  follower_id  String
  following_id String
  created_at   DateTime @default(now())
  follower     User     @relation("UserFollowing", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowers", fields: [following_id], references: [id], onDelete: Cascade)

  @@id([follower_id, following_id])
  @@index([follower_id])
}

model Like {
  user_id String
  pic_id  String
  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, pic_id])
  @@index([user_id, pic_id])
}

model Picture {
  id               String                   @id @default(cuid())
  user_id          String
  description      String?                  @db.VarChar(4000)
  alt              String                   @db.VarChar(150)
  title            String                   @db.VarChar(60)
  created_at       DateTime                 @default(now())
  search_vector    Unsupported("tsvector")?
  collection_items CollectionItem[]
  engagement       Engagement?
  likes            Like[]
  metadata         Metadata?
  tags             PicTag[]
  user             User                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  src              Src[]

  @@index([user_id, id])
  @@index([search_vector], map: "picture_search_idx", type: Gin)
  @@index([title(ops: raw("gin_trgm_ops"))], map: "picture_trgm_idx", type: Gin)
}

model Src {
  id         Int        @id @default(autoincrement())
  pic_id     String
  resolution Resolution
  url        String
  size       Int
  height     Int
  width      Int
  picture    Picture    @relation(fields: [pic_id], references: [id], onDelete: Cascade)

  @@index([pic_id])
  @@index([pic_id, resolution], map: "src_pic_res_idx")
}

model Metadata {
  pic_id         String  @id
  dominant_color String
  blurhash       String
  others         Json?
  picture        Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)
}

model Tag {
  id            Int                      @id @default(autoincrement())
  name          String                   @unique @db.VarChar(30)
  search_vector Unsupported("tsvector")?
  pictures      PicTag[]

  @@index([search_vector], map: "tag_search_idx", type: Gin)
  @@index([name(ops: raw("gin_trgm_ops"))], map: "tag_trgm_idx", type: Gin)
}

model PicTag {
  pic_id  String
  tag_id  Int
  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([pic_id, tag_id])
  @@index([tag_id])
}

model Engagement {
  pic_id     String   @id
  views      Int      @default(0)
  downloads  Int      @default(0)
  likes      Int      @default(0)
  updated_at DateTime @default(now())
  picture    Picture  @relation(fields: [pic_id], references: [id], onDelete: Cascade)
}

model Collection {
  id          String           @id @default(cuid())
  creator_id  String
  title       String           @db.VarChar(60)
  description String?          @db.VarChar(4000)
  cover_image String           @default("https://placehold.net/main.svg")
  visibility  Visibility       @default(PUBLIC)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  creator     User             @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@index([creator_id, id])
}

model CollectionItem {
  collection_id String
  pic_id        String
  collection    Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  picture       Picture    @relation(fields: [pic_id], references: [id], onDelete: Cascade)

  @@id([collection_id, pic_id])
}

enum Resolution {
  ORIGINAL
  LARGE
  MEDIUM
  SMALL
  THUMBNAIL
}

enum Visibility {
  PUBLIC
  PRIVATE
}
