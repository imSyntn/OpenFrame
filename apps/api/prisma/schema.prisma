// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(80)
  email       String   @unique
  google_id   String?
  password    String?
  joined_at   DateTime @default(now())
  avatar      String   @default("https://cdn-icons-png.flaticon.com/512/3177/3177440.png")
  bio         String?  @db.VarChar(160)
  is_verified Boolean  @default(false)
  location    String?  @db.VarChar(100)

  Links      Links[]
  metrics    Metrics?
  followers  Follow[]     @relation("UserFollowing")
  following  Follow[]     @relation("UserFollowers")
  pictures   Picture[]
  likes      Like[]
  collection Collection[]
}

model Links {
  id      Int    @id @default(autoincrement())
  user_id String
  name    String @db.VarChar(30)
  url     String @db.VarChar(150)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, name])
  @@index([user_id])
}

model Metrics {
  user_id         String @id
  follower        Int    @default(0)
  following       Int    @default(0)
  total_downloads Int    @default(0)
  total_likes     Int    @default(0)
  user            User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Follow {
  follower_id  String
  following_id String
  created_at   DateTime @default(now())
  follower     User     @relation("UserFollowing", fields: [follower_id], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowers", fields: [following_id], references: [id], onDelete: Cascade)

  @@id([follower_id, following_id])
  @@index([follower_id])
}

model Like {
  user_id String
  pic_id  String

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)

  @@id([user_id, pic_id])
  @@index([user_id])
}

model Picture {
  id          String   @id @default(cuid())
  user_id     String
  description String?  @db.VarChar(4000)
  alt         String   @db.VarChar(150)
  title       String   @db.VarChar(60)
  created_at  DateTime @default(now())

  src             Src[]
  metadata        Metadata?
  user            User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  likes           Like[]
  tags            PicTag[]
  collectionItems CollectionItem[]
  engagement      Engagement?

  @@index([user_id, id])
}

enum Resolution {
  ORIGINAL
  LARGE
  MEDIUM
  SMALL
  THUMBNAIL
}

enum Type {
  JPG
  PNG
  WEBP
}

model Src {
  id         Int        @id @default(autoincrement())
  pic_id     String
  resolution Resolution
  url        String
  type       Type
  size       Int

  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)

  @@index([pic_id])
}

model Metadata {
  pic_id         String  @id
  camera         String?
  lens           String?
  shutter        String?
  iso            String?
  focal_length   String?
  aperture       String?
  dominant_color String
  blurhash       String

  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(30)

  pictures PicTag[]
}

model PicTag {
  pic_id String
  tag_id Int

  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([pic_id, tag_id])
  @@index([tag_id])
}

model Engagement {
  pic_id     String   @id
  views      Int      @default(0)
  downloads  Int      @default(0)
  likes      Int      @default(0)
  updated_at DateTime @updatedAt

  picture Picture @relation(fields: [pic_id], references: [id], onDelete: Cascade)
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model Collection {
  id          String     @id @default(cuid())
  creator_id  String
  title       String     @db.VarChar(60)
  description String?    @db.VarChar(4000)
  cover_image String     @default("https://placehold.net/main.svg")
  visibility  Visibility @default(PUBLIC)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  creator User             @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  items   CollectionItem[]

  @@index([creator_id])
}

model CollectionItem {
  collection_id String
  pic_id        String

  collection Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  picture    Picture    @relation(fields: [pic_id], references: [id], onDelete: Cascade)

  @@id([collection_id, pic_id])
}
